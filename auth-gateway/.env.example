# Auth Gateway Environment
# Copy to .env and fill in real values. Never commit .env.

AUTH_PORT=4000

# 32+ character random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMAC_SECRET=replace_with_32_char_random_hex_string

# RSA-2048 key pair for RS256 JWT signing.
# Generate with: node scripts/keygen.js — outputs JWT_PRIVATE_KEY and JWT_PUBLIC_KEY lines ready to paste here.
# Newlines must be encoded as \n literals (the server replaces them back).
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----

# Audience claim embedded in every issued JWT. Client apps must validate this.
JWT_AUDIENCE=verdant-table-apps

# Public URL of this gateway (used to build the QR verify URL)
AUTH_GATEWAY_URL=http://localhost:4000

# Comma-separated origins allowed to call this gateway
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:3000
