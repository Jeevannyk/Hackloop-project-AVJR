# ─── Database ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/restaurant

# ─── Mailgun (email confirmation) ────────────────────────────────────────────
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain.com

# ─── Admin credentials ────────────────────────────────────────────────────────
# Username (default: admin)
ADMIN_USERNAME=admin

# bcrypt hash of the admin password — NEVER store the plaintext password.
# Generate with: node scripts/setup-admin.js
ADMIN_PASSWORD_HASH=$2a$12$replacethiswiththeoutputofsetup-admin

# Secret used to sign and verify admin session JWTs.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# setup-admin.js outputs this automatically alongside the hash.
ADMIN_JWT_SECRET=replace-with-64-char-random-hex

# ─── Auth gateway (optional — activates RS256 customer token verification) ───
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----
JWT_AUDIENCE=verdant-table-apps

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
